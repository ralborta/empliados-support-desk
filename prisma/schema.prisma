// Prisma schema para Empliados Support Desk
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgentRole {
  ADMIN
  SUPPORT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketCategory {
  TECH_SUPPORT
  BILLING
  SALES
  OTHER
}

enum TicketChannel {
  WHATSAPP
  EMAIL
  WEB
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL_NOTE
}

enum MessageFrom {
  CUSTOMER
  BOT
  HUMAN
}

enum TicketEventType {
  STATUS_CHANGED
  ASSIGNED
  TAGGED
  PRIORITY_CHANGED
  AUTO_REPLY
  ESCALATED
}

enum AgentNotificationType {
  ASSIGNED
  REASSIGNED
}

model Customer {
  id                       String    @id @default(cuid())
  phone                    String    @unique
  /// Nombre de la persona (contacto en CRM)
  name                     String?
  /// Nombre de la empresa / razón social
  companyName              String?
  /// ID del contacto en el sistema externo para la empresa elegida (uso interno del bot; no mostrar en panel)
  selectedCompanyContactId Int?
  /// SessionToken Wara cacheado para el contacto elegido (CreateChatBotToken).
  waraSessionToken         String?
  waraSessionAt            DateTime?
  /// Matrícula o patente asociada al cliente
  licensePlate             String?
  /// Si está seteado, Atilio no envía auto-respuestas; el agente responde manual por el panel/WhatsApp
  botPausedAt              DateTime?
  /// Trámite pendiente de confirmación (certificado/odómetro/mantenimiento) esperando CONFIRMO del cliente.
  /// Estado explícito — reemplaza la inferencia por regex sobre el texto del hilo. Null = sin trámite pendiente.
  pendingAction            Json?
  tickets                  Ticket[]
  createdAt                DateTime  @default(now())
}

model AgentUser {
  id              String              @id @default(cuid())
  email           String              @unique
  name            String
  phone           String // Legacy; avisos al asesor van al panel, no WhatsApp
  role            AgentRole
  /// Hash scrypt para login al panel (opcional; si null, no puede iniciar sesión).
  passwordHash    String?
  /// Asesor conectado al backoffice y disponible para recibir casos (solo rol SUPPORT).
  sessionActive   Boolean             @default(false)
  sessionActiveAt DateTime?
  /// Tras logout: liberar casos a la cola cuando llegue este timestamp (gracia 5 min).
  casesReleaseAt  DateTime?
  /// Último ping del panel; define si el asesor está realmente conectado.
  lastSeenAt      DateTime?
  tickets         Ticket[]            @relation("AgentAssignments")
  notifications   AgentNotification[]
  createdAt       DateTime            @default(now())

  @@index([sessionActive])
  @@index([casesReleaseAt])
  @@index([lastSeenAt])
}

model AgentNotification {
  id          String                @id @default(cuid())
  agentUserId String
  agentUser   AgentUser             @relation(fields: [agentUserId], references: [id], onDelete: Cascade)
  ticketId    String
  ticket      Ticket                @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type        AgentNotificationType @default(ASSIGNED)
  readAt      DateTime?
  createdAt   DateTime              @default(now())

  @@index([agentUserId, readAt])
  @@index([ticketId])
}

model Ticket {
  id                 String              @id @default(cuid())
  code               String              @unique
  customerId         String
  customer           Customer            @relation(fields: [customerId], references: [id])
  contactName        String // Nombre de la persona que contacta (ej: "Juan Pérez")
  title              String
  status             TicketStatus
  priority           TicketPriority
  category           TicketCategory
  /// Clave Wara (MISSING_REPORT, ODOMETER_CHANGE, …) inferida del último mensaje del cliente
  incidentType       String?
  channel            TicketChannel
  assignedToUserId   String?
  assignedTo         AgentUser?          @relation("AgentAssignments", fields: [assignedToUserId], references: [id])
  lastMessageAt      DateTime            @default(now())
  // AI-generated summaries
  aiSummary          String? // Resumen de la conversación generado por IA
  resolution         String? // Conclusión de cómo se resolvió el caso
  resolvedByAI       Boolean             @default(false) // Si fue resuelto automáticamente por IA
  messages           TicketMessage[]
  events             TicketEvent[]
  tags               TicketTag[]
  agentNotifications AgentNotification[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([status])
  @@index([priority])
  @@index([customerId])
  @@index([assignedToUserId])
  @@index([lastMessageAt])
}

/// Contador diario para códigos DDMMYY + secuencia (zona Argentina).
model TicketDailySequence {
  dayKey    String   @id
  lastSeq   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketMessage {
  id                String           @id @default(cuid())
  ticketId          String
  ticket            Ticket           @relation(fields: [ticketId], references: [id])
  direction         MessageDirection
  from              MessageFrom
  text              String
  attachments       Json? // Array de { url, type, name } para imágenes y archivos
  rawPayload        Json
  externalMessageId String?          @unique
  createdAt         DateTime         @default(now())

  @@index([ticketId, createdAt])
}

model TicketEvent {
  id        String          @id @default(cuid())
  ticketId  String
  ticket    Ticket          @relation(fields: [ticketId], references: [id])
  type      TicketEventType
  payload   Json
  createdAt DateTime        @default(now())

  @@index([ticketId, createdAt])
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  tickets   TicketTag[]
  createdAt DateTime    @default(now())
}

model TicketTag {
  ticketId String
  tagId    String
  ticket   Ticket @relation(fields: [ticketId], references: [id])
  tag      Tag    @relation(fields: [tagId], references: [id])

  @@id([ticketId, tagId])
}

/// Prompts de subflujos Atilio editables desde /configuracion (fuente de verdad en panel; sync BB vía script MCP).
model BotPromptModule {
  key                String   @id
  name               String
  description        String?
  flowLabel          String?
  content            String   @db.Text
  sortOrder          Int      @default(0)
  builderbotFlowId   String?
  builderbotAnswerId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
